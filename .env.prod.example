# ─── Domínio & Cloudflare ─────────────────────────────────────────────────────
DOMAIN=my-dask.com

# Token do tunnel (Cloudflare Zero Trust → Tunnels → <tunnel> → Configure → Token)
CLOUDFLARE_TUNNEL_TOKEN=cole-aqui-o-token-do-tunnel

# ─── Base de dados ────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=muda-para-uma-password-forte
POSTGRES_DB=dask

# ─── API ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3333
API_PREFIX=/api/v1

# JWT
JWT_SECRET=minimo-16-chars-muda-isto
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=minimo-32-chars-muda-isto-aqui-refresh
JWT_REFRESH_EXPIRES_IN=7d

# Segurança
HASH_PEPPER=minimo-32-chars-muda-isto-aqui-pepper
AUTH_MAX_FAILURES=5
CORS_ALLOWED_ORIGINS=https://my-dask.com
CSRF_SECRET=minimo-32-chars-muda-isto-aqui-csrf
COOKIE_SAME_SITE=strict

# OAuth / OIDC (server-side callbacks)
GOOGLE_OAUTH_CLIENT_ID=change-me-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=change-me-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://my-dask.com/api/v1/auth/google/callback

MICROSOFT_OAUTH_CLIENT_ID=change-me-microsoft-client-id
MICROSOFT_OAUTH_CLIENT_SECRET=change-me-microsoft-client-secret
MICROSOFT_OAUTH_TENANT_ID=common
MICROSOFT_OAUTH_REDIRECT_URI=https://my-dask.com/api/v1/auth/microsoft/callback

# Email / WhatsApp
RESEND_API_KEY=
EMAIL_FROM=Dask <noreply@my-dask.com>
COMMUNICATION_CREDENTIAL_SECRET=replace-with-random-32-plus-char-communication-secret
AUTOMATION_EMAIL_SEND_MODE=mock
AUTOMATION_EMAIL_PROVIDER=mock
AUTOMATION_WHATSAPP_SEND_MODE=mock
AUTOMATION_WHATSAPP_PROVIDER=mock
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_GRAPH_API_VERSION=v23.0
META_WHATSAPP_WEBHOOK_ENABLED=false
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=replace-with-random-meta-verify-token
META_WHATSAPP_WEBHOOK_APP_SECRET=replace-with-meta-app-secret

# Logs & Workers
LOG_LEVEL=info
ENABLE_WORKERS=true

# Billing / Stripe Platform
# Production gate requires live Stripe env; never deploy sk_test/pk_test here.
STRIPE_ENVIRONMENT=live
STRIPE_SECRET_KEY=sk_live_replace_with_real_secret_key
STRIPE_PUBLIC_KEY=pk_live_replace_with_real_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_real_platform_webhook_secret
BILLING_PORTAL_TOKEN_SECRET=replace-with-random-32-plus-char-portal-secret
STRIPE_WEBHOOK_SECRET_FISCAL=
STRIPE_PRICE_ID_PERSONAL_MONTHLY=price_replace_personal_monthly
STRIPE_PRICE_ID_BASIC_MONTHLY=price_replace_basic_monthly
STRIPE_PRICE_ID_PRO_MONTHLY=price_replace_pro_monthly
STRIPE_PRICE_ID_BUSINESS_MONTHLY=price_replace_business_monthly
STRIPE_PRICE_ID_ENTERPRISE_MONTHLY=

# Stripe Connect
STRIPE_CONNECT_APPLICATION_FEE_BPS=500
STRIPE_CONNECT_REQUIRED_CAPABILITIES=charges_enabled,transfers,card_payments

# Fiscal / Focus
# Production gate requires producao and an explicit HTTPS production base URL.
FOCUS_API_ENVIRONMENT=producao
FOCUS_API_BASE_URL=https://api.focusnfe.com.br/v2
FOCUS_API_TIMEOUT_MS=10000
FOCUS_API_RETRY_ATTEMPTS=2
FOCUS_API_RETRY_BACKOFF_MS=250
FOCUS_WEBHOOK_SECRET=replace-with-random-32-plus-char-focus-webhook-secret
