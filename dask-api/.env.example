NODE_ENV=development
PORT=3333
API_PREFIX=/api/v1

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dask
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-minimum-16-chars-jwt-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-minimum-32-chars-refresh-secret-here
JWT_REFRESH_EXPIRES_IN=7d

# Password hashing
HASH_PEPPER=change-me-minimum-32-chars-hash-pepper-do-not-share
AUTH_MAX_FAILURES=5

# Browser security
# Comma-separated allowlist. Example:
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://app.example.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

# CSRF secret for signed double-submit token generation/validation.
CSRF_SECRET=change-me-minimum-32-chars-csrf-secret

# strict | lax | none
# If using none in production, HTTPS (Secure cookies) is mandatory.
COOKIE_SAME_SITE=strict

# OAuth / OIDC (server-side callbacks)
GOOGLE_OAUTH_CLIENT_ID=change-me-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=change-me-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3333/api/v1/auth/google/callback

MICROSOFT_OAUTH_CLIENT_ID=change-me-microsoft-client-id
MICROSOFT_OAUTH_CLIENT_SECRET=change-me-microsoft-client-secret
MICROSOFT_OAUTH_TENANT_ID=common
MICROSOFT_OAUTH_REDIRECT_URI=http://localhost:3333/api/v1/auth/microsoft/callback

# Email (Resend — https://resend.com)
# Deixe em branco para desativar envio de e-mails (em dev o token de reset é retornado na resposta HTTP).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Dask <noreply@seudominio.com>
APP_URL=http://localhost:5173
# Webhook Resend. If RESEND_WEBHOOK_ENABLED=true in production, secret is required.
RESEND_WEBHOOK_ENABLED=false
RESEND_WEBHOOK_SECRET=change-me-resend-webhook-secret

# Meta WhatsApp webhooks. If enabled in production, verify token and app secret are required.
META_WHATSAPP_WEBHOOK_ENABLED=false
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-me-meta-verify-token
META_WHATSAPP_WEBHOOK_APP_SECRET=change-me-meta-app-secret

# Logging presets (copie os 3 valores do preset desejado)
# DEV BALANCED (default)
LOG_LEVEL=info
LOG_PRETTY=auto
LOG_DEBUG_CHANNELS=
#
# DEV TURBO
# LOG_LEVEL=debug
# LOG_PRETTY=always
# LOG_DEBUG_CHANNELS=http.request,db.query,queue.enqueue,worker.jobs,ai.openai.chat,ai.openai.embedding,outbox.relay
#
# PROD SAFE
# LOG_LEVEL=info
# LOG_PRETTY=never
# LOG_DEBUG_CHANNELS=
#
# Opcoes:
# LOG_LEVEL=trace|debug|info|warn|error|fatal|silent
# LOG_PRETTY=auto|always|never
# LOG_DEBUG_CHANNELS=lista separada por virgula ou *
# LOG_DB_QUERY_MIN_DURATION_MS=10
# LOG_DB_QUERY_INCLUDE_TX_CONTROL=false
# LOG_DB_QUERY_INCLUDE_OUTBOX_POLL=false
LOG_DB_QUERY_MIN_DURATION_MS=10
LOG_DB_QUERY_INCLUDE_TX_CONTROL=false
LOG_DB_QUERY_INCLUDE_OUTBOX_POLL=false
ENABLE_WORKERS=true
OUTBOX_RELAY_INTERVAL_MS=1000
OUTBOX_RELAY_BATCH_SIZE=50
OUTBOX_RELAY_MAX_RETRIES=20

# Stripe Billing
# Chaves disponíveis em https://dashboard.stripe.com/apikeys
STRIPE_ENVIRONMENT=test
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Dedicated secret for signed billing portal links. Required in production.
# Dev/test: set an explicit local-only value when exercising portal links; there is no implicit default.
BILLING_PORTAL_TOKEN_SECRET=change-me-minimum-32-chars-billing-portal-secret
# Segredo dedicado ao endpoint /integrations/stripe/webhook/fiscal. Obrigatorio em producao; sem fallback.
STRIPE_WEBHOOK_SECRET_FISCAL=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# IDs de preço criados no dashboard da Stripe (Products > Prices)
# Criar produto "Dask Pessoal" com preço R$19,90/mês e "Dask Business" com R$99,00/mês
STRIPE_PRICE_ID_PERSONAL_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_BASIC_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_PRO_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_BUSINESS_MONTHLY=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_ENTERPRISE_MONTHLY=
# Nota: o checkout self-service atual usa os valores internos Basic/Pro/Business.
# Estes price IDs ficam opcionais/legados para integracoes e smokes antigos.

# Stripe Connect (repasse: seus clientes cobrando clientes deles)
# Taxa da plataforma em basis points (500 = 5%)
STRIPE_CONNECT_APPLICATION_FEE_BPS=500
# Required capabilities checked before Connect checkout flows.
STRIPE_CONNECT_REQUIRED_CAPABILITIES=charges_enabled,transfers,card_payments
# Optional real provider smokes. Unit tests do not run these files.
DASK_REAL_SMOKE=false
# Release/staging gate: enables every real provider smoke and fails when any required env is missing.
DASK_RELEASE_REAL_SMOKE=false
DASK_REAL_SMOKE_STRIPE_PLATFORM=false
DASK_REAL_SMOKE_STRIPE_CONNECT=false
DASK_REAL_SMOKE_ALLOW_LIVE_STRIPE=false
DASK_STRIPE_CONNECT_ACCOUNT_ID=acct_xxxxxxxxxxxxxxxxx
DASK_STRIPE_CONNECT_REQUIRED_CAPABILITIES=charges_enabled,transfers,card_payments
# Legacy alias still supported for Stripe Platform smoke.
DASK_STRIPE_REAL_SMOKE=false

# Focus NFe API v2 (fiscal)
# Obrigatorio em producao para chamadas reais ao provider Focus.
FOCUS_API_ENVIRONMENT=homologacao
FOCUS_API_BASE_URL=https://api.focusnfe.com.br/v2
# Timeout/retry seguros para leituras Focus. Operacoes mutantes nao sao retentadas automaticamente.
FOCUS_API_TIMEOUT_MS=10000
FOCUS_API_RETRY_ATTEMPTS=2
FOCUS_API_RETRY_BACKOFF_MS=250
# Obrigatorio em producao para proteger o endpoint /integrations/focus/webhook.
FOCUS_WEBHOOK_SECRET=change-me-focus-webhook-secret
DASK_REAL_SMOKE_FOCUS=false
DASK_REAL_SMOKE_ALLOW_FOCUS_PRODUCTION=false
DASK_FOCUS_SMOKE_TOKEN=
DASK_FOCUS_SMOKE_CNPJ=
DASK_FOCUS_SMOKE_ENVIRONMENT=homologacao

# Commercial intake webhooks (/integrations/commercial-intake/webhook/:source)
# Obrigatorio em producao. Envie como Authorization: Bearer <secret>,
# X-Commercial-Intake-Secret, X-Commercial-Webhook-Secret ou assinatura HMAC SHA-256 em X-Dask-Signature.
COMMERCIAL_INTAKE_WEBHOOK_SECRET=change-me-commercial-intake-webhook-secret
# Somente dev/test local: permite webhook sem secret quando definido explicitamente como true.
COMMERCIAL_INTAKE_WEBHOOK_ALLOW_INSECURE=false

# Marketing provider webhooks (/integrations/marketing/email-events/:provider)
# Required in production.
MARKETING_WEBHOOK_SECRET=change-me-marketing-webhook-secret

# URL pública do app (usada para redirect após checkout)
APP_PUBLIC_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:3333

# AI providers
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
AI_CHAT_MODEL=gpt-4.1-mini
DASK_REAL_SMOKE_AI=false
AI_EMBEDDING_MODEL=text-embedding-3-large
AI_MAX_REQUESTS_PER_MIN_WORKSPACE=120
AI_MAX_REQUESTS_PER_MIN_AGENT=40
AI_MAX_TOKENS_PER_DAY_WORKSPACE=2500000
AI_MAX_TOKENS_PER_DAY_AGENT=900000
AI_EMBEDDING_CHUNK_SIZE=900
AI_EMBEDDING_CHUNK_OVERLAP=140
AI_EMBEDDING_VERSION=v1
