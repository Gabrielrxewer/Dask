generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum AuditSeverity {
  INFO
  WARNING
  ERROR
}

enum CustomFieldType {
  TEXT
  LONG_TEXT
  NUMBER
  DATE
  DATETIME
  BOOLEAN
  SELECT
  MULTI_SELECT
  USER
  CHECKLIST
  PRIORITY
  STATUS
  TAG
  SCHEDULE
  WORK_ITEM_TYPE
}

enum AuthProvider {
  GOOGLE
  MICROSOFT
}

enum WorkspaceKind {
  PERSONAL
  CORPORATE
}

enum SubscriptionPlan {
  PERSONAL
  BUSINESS
}

enum SubscriptionStatus {
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

enum ConnectPaymentOrderStatus {
  DRAFT
  CHECKOUT_OPEN
  CHECKOUT_COMPLETED
  PENDING
  PAID
  FAILED
  CANCELED
  REFUNDED
}

enum ConnectCatalogItemKind {
  PRODUCT
  SERVICE
}

enum ConnectCatalogBillingType {
  ONE_TIME
  ASSINATURA
  SUBSCRIPTION
}

enum ConnectCatalogRecurringInterval {
  DAY
  WEEK
  MONTH
  YEAR
}

enum FiscalProvider {
  FOCUS
}

enum FiscalDirection {
  OUTBOUND
  INBOUND
}

enum FiscalDocumentType {
  NFE
  NFSE
}

enum FiscalDocumentOrigin {
  MANUAL_PRODUCT
  MANUAL_SERVICE
  CATALOG_PRODUCT
  CATALOG_SERVICE
  STRIPE_PAYMENT
  STRIPE_SUBSCRIPTION
  EXTERNAL_RECEIVED_NFE
  EXTERNAL_RECEIVED_NFSE
}

enum FiscalSourceSystem {
  INTERNAL
  STRIPE
  FOCUS
  MDE
  NFSER
}

enum FiscalDocumentStatus {
  DRAFT
  READY_TO_ISSUE
  ISSUING
  AUTHORIZED
  PROCESSING
  PENDING_REVIEW
  REJECTED
  CANCELLED
  FAILED
  RECEIVED
  MANIFEST_PENDING
  MANIFESTED
  SYNCED
}

enum FiscalIssueStatus {
  NOT_STARTED
  PROCESSING
  AUTHORIZED
  REJECTED
  CANCELLED
  FAILED
}

enum FiscalPartyRole {
  EMITTER
  RECIPIENT
  TAKER
  SUPPLIER
}

enum FiscalReceivedType {
  NFE_MDE
  NFSE_NFSER
}

enum FiscalReceivedStatus {
  RECEIVED
  MANIFEST_PENDING
  MANIFESTED
  SYNCED
  FAILED
}

enum FiscalSyncType {
  RECEIVED_NFE
  RECEIVED_NFSE
  PENDING_RECONCILIATION
  OUTBOUND_STATUS
}

enum FiscalSyncTrigger {
  MANUAL
  SCHEDULED
  WEBHOOK
  RETRY
}

enum FiscalSyncStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum FiscalWebhookSource {
  FOCUS
  STRIPE
}

enum FiscalWebhookStatus {
  RECEIVED
  PROCESSED
  FAILED
  DUPLICATE
}

enum FiscalCatalogItemType {
  PRODUCT
  SERVICE
}

enum FiscalDraftStatus {
  DRAFT
  READY
  ISSUED
  CANCELLED
}

enum FiscalIntegrationDirection {
  OUTBOUND
  INBOUND
}

enum FiscalIntegrationStatus {
  SUCCESS
  ERROR
}

enum LeadStatus {
  CAPTURED
  QUALIFIED
  DISTRIBUTED
  FOLLOW_UP
  NURTURING
  CONVERTED
  LOST
}

enum LeadSource {
  MANUAL
  API
  WEBHOOK
  IMPORT
  INTEGRATION
}

enum LeadQualificationStatus {
  UNQUALIFIED
  MQL
  SQL
  DISQUALIFIED
}

enum LeadDistributionStatus {
  UNASSIGNED
  ASSIGNED
  ACCEPTED
  REASSIGNED
}

enum LeadDistributionStrategy {
  MANUAL
  ROUND_ROBIN
  RULE_BASED
  TERRITORY
}

enum LeadActivityType {
  CAPTURED
  QUALIFIED
  DISTRIBUTED
  FOLLOW_UP
  NURTURE_TOUCH
  CONVERTED
  STATUS_CHANGED
  NOTE
}

enum LeadNurtureStatus {
  DRAFT
  SCHEDULED
  SENT
  RESPONDED
  SKIPPED
  FAILED
}

enum LeadConversionType {
  CUSTOMER
  OPPORTUNITY
  DEAL
  SUBSCRIPTION
}

enum LeadIntegrationSource {
  GENERIC_WEBHOOK
  ZAPIER
  MAKE
  N8N
  HUBSPOT
  RD_STATION
}

enum LeadIntegrationEventStatus {
  RECEIVED
  PROCESSED
  FAILED
  DUPLICATE
}

enum MarketingCampaignStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  SCHEDULED
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum MarketingCampaignChannel {
  EMAIL
  NEWSLETTER
}

enum MarketingCampaignObjective {
  LEAD_NURTURE
  ONBOARDING
  REACTIVATION
  BILLING_REMINDER
  RENEWAL
  EXPANSION
  PRODUCT_UPDATE
  NEWSLETTER
  CUSTOM
}

enum MarketingAudienceType {
  STATIC
  DYNAMIC
}

enum MarketingEventType {
  CAMPAIGN_CREATED
  CAMPAIGN_UPDATED
  CAMPAIGN_REVIEW_REQUESTED
  CAMPAIGN_APPROVED
  CAMPAIGN_SCHEDULED
  CAMPAIGN_LAUNCHED
  SEND_QUEUED
  EMAIL_SENT
  EMAIL_DELIVERED
  EMAIL_OPENED
  EMAIL_CLICKED
  EMAIL_BOUNCED
  EMAIL_COMPLAINT
  EMAIL_UNSUBSCRIBED
  LEAD_SCORE_CHANGED
  AUTOMATION_ENROLLED
  AUTOMATION_EXITED
  OPPORTUNITY_INFLUENCED
  CUSTOMER_CONVERTED
  BILLING_SIGNAL_TRIGGERED
  AI_GENERATED
  AI_IMPROVED
  TASK_CREATED
  DOCUMENT_LINKED
}

enum MarketingConsentStatus {
  OPT_IN
  OPT_OUT
  UNSUBSCRIBED
  UNKNOWN
}

enum MarketingMessageKind {
  MARKETING
  TRANSACTIONAL
}

enum MarketingSendStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  UNSUBSCRIBED
  FAILED
  SKIPPED
}

enum MarketingAutomationStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum MarketingAutomationStepKind {
  TRIGGER
  CONDITION
  DELAY
  ACTION
  BRANCH
  EXIT
}

enum MarketingAutomationEnrollmentStatus {
  ACTIVE
  COMPLETED
  EXITED
  FAILED
}

enum MarketingAttributionType {
  FIRST_TOUCH
  LAST_TOUCH
  MULTI_TOUCH
}

enum MarketingAttributionEntityType {
  LEAD
  OPPORTUNITY
  CUSTOMER
  SUBSCRIPTION
  INVOICE
}

model User {
  id                       String                    @id @default(uuid())
  email                    String                    @unique
  name                     String
  emailVerified            Boolean                   @default(false)
  isPlatformAdmin          Boolean                   @default(false)
  passwordHash             String?
  // 0 = legacy plain-bcrypt (pre-migration), 1 = HMAC-SHA256+bcrypt with pepper
  passwordHashVersion      Int                       @default(0)
  loginFailureCount        Int                       @default(0)
  lockedUntil              DateTime?
  preferences              Json?
  // Billing / Stripe
  stripeCustomerId         String?                   @unique
  subscriptionPlan         SubscriptionPlan?
  subscriptionStatus       SubscriptionStatus?
  subscriptionId           String?
  currentPeriodEnd         DateTime?
  hasActiveSubscription    Boolean                   @default(false)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  organizations            OrganizationMembership[]
  teams                    TeamMembership[]
  workspaces               WorkspaceMembership[]
  createdItems             Item[]                    @relation("ItemCreatedBy")
  assignedItems            Item[]                    @relation("ItemAssignee")
  updatedItems             Item[]                    @relation("ItemUpdatedBy")
  comments                 ItemComment[]
  updatedCustomFieldValues CustomFieldValue[]        @relation("CustomFieldValueUpdatedBy")
  updatedViewPlacements    WorkItemViewPlacement[]   @relation("WorkItemViewPlacementUpdatedBy")
  refreshTokens            RefreshToken[]
  resetTokens              PasswordResetToken[]
  verificationTokens       EmailVerificationToken[]
  externalIdentities       ExternalIdentity[]
  subscriptions            Subscription[]
  sentWorkspaceInvites     WorkspaceInvite[]        @relation("WorkspaceInviteSentBy")
  acceptedWorkspaceInvites WorkspaceInvite[]        @relation("WorkspaceInviteAcceptedBy")
  ownedLeads               Lead[]                  @relation("LeadOwner")
  leadActivities           LeadActivity[]          @relation("LeadActivityActor")
  leadAssignments          LeadAssignment[]        @relation("LeadAssignmentActor")
  leadConversions          LeadConversion[]        @relation("LeadConversionActor")
  leadNurtureTouches       LeadNurtureTouch[]      @relation("LeadNurtureActor")
}

model Subscription {
  id                       String             @id @default(uuid())
  userId                   String
  stripeCustomerId         String
  stripeSubscriptionId     String             @unique
  stripeCheckoutSessionId  String?
  planCode                 SubscriptionPlan
  status                   SubscriptionStatus
  currency                 String             @default("brl")
  amount                   Int                // in cents
  interval                 String             @default("month")
  currentPeriodStart       DateTime?
  currentPeriodEnd         DateTime?
  cancelAtPeriodEnd        Boolean            @default(false)
  lastWebhookEvent         String?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  user                     User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeCustomerId])
}

model ExternalIdentity {
  id               String       @id @default(uuid())
  userId           String
  provider         AuthProvider
  providerSubject  String
  providerTenantId String?
  emailAtProvider  String?
  emailVerified    Boolean?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject, providerTenantId])
  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  // familyId links tokens issued from the same login session;
  // reuse of a revoked token triggers revocation of the entire family
  familyId  String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Organization {
  id              String                    @id @default(uuid())
  name            String
  slug            String                    @unique
  settings        Json?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  memberships     OrganizationMembership[]
  teams           Team[]
  workspaces      Workspace[]
}

model OrganizationMembership {
  id              String                    @id @default(uuid())
  organizationId  String
  userId          String
  role            MembershipRole            @default(MEMBER)
  permissions     Json?
  createdAt       DateTime                  @default(now())
  organization    Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model Team {
  id              String                    @id @default(uuid())
  organizationId  String
  name            String
  metadata        Json?
  createdAt       DateTime                  @default(now())
  organization    Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships     TeamMembership[]
}

model TeamMembership {
  id              String                    @id @default(uuid())
  teamId          String
  userId          String
  role            MembershipRole            @default(MEMBER)
  permissions     Json?
  createdAt       DateTime                  @default(now())
  team            Team                      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Workspace {
  id                     String                    @id @default(uuid())
  organizationId         String?
  kind                   WorkspaceKind             @default(CORPORATE)
  name                   String
  key                    String
  config                 Json?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  organization           Organization?             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships            WorkspaceMembership[]
  boards                 Board[]
  templates              BoardTemplate[]
  itemTypes              WorkItemType[]
  workflowStates         WorkflowState[]
  boardColumns           BoardColumn[]
  columnStateMappings    ColumnStateMapping[]
  tagDefinitions         TagDefinition[]
  customFieldDefinitions CustomFieldDefinition[]
  fieldBindings          WorkItemFieldBinding[]
  preferences            WorkspacePreferences?
  workItems              Item[]
  automationRules        AutomationRule[]
  automationViews        AutomationView[]
  automationViewColumns  AutomationViewColumn[]
  itemViewPlacements     WorkItemViewPlacement[]
  automationExecutions   AutomationExecution[]
  aiAgents               AIAgent[]
  aiAgentRuns            AIAgentRun[]
  invites                WorkspaceInvite[]
  documents              WorkspaceDocument[]
  workItemDocumentLinks  WorkItemDocumentLink[]
  connectPaymentOrders   ConnectPaymentOrder[]
  connectCatalogItems    ConnectCatalogItem[]
  fiscalCompanyConfigs   FiscalCompanyConfig[]
  fiscalDocuments        FiscalDocument[]
  fiscalEmissionDrafts   FiscalEmissionDraft[]
  fiscalReceivedDocuments FiscalReceivedDocument[]
  fiscalSyncRuns         FiscalSyncRun[]
  fiscalWebhookEvents    FiscalWebhookEvent[]
  fiscalIntegrationLogs  FiscalIntegrationLog[]
  fiscalCatalogProfiles  FiscalCatalogProfile[]
  fiscalOperationTemplates FiscalOperationTemplate[]
  leads                  Lead[]
  leadActivities         LeadActivity[]
  leadAssignments        LeadAssignment[]
  leadNurtureTouches     LeadNurtureTouch[]
  leadConversions        LeadConversion[]
  leadIntegrationEvents  LeadIntegrationEvent[]
  marketingCampaigns     MarketingCampaign[]
  marketingCampaignVariants MarketingCampaignVariant[]
  marketingAudienceSegments MarketingAudienceSegment[]
  marketingContactPreferences MarketingContactPreference[]
  marketingEmailTemplates MarketingEmailTemplate[]
  marketingAutomationFlows MarketingAutomationFlow[]
  marketingAutomationSteps MarketingAutomationStep[]
  marketingAutomationEnrollments MarketingAutomationEnrollment[]
  marketingEvents        MarketingEvent[]
  marketingAttributions  MarketingAttribution[]
  marketingSenderProfiles MarketingSenderProfile[]
  marketingConsentRecords MarketingConsentRecord[]
  marketingLeadScoreEvents MarketingLeadScoreEvent[]
  marketingContentAssets MarketingContentAsset[]
  marketingCampaignSends MarketingCampaignSend[]

  @@unique([organizationId, key])
}

model Lead {
  id                   String                    @id @default(uuid())
  workspaceId          String
  externalSource       LeadIntegrationSource?
  externalId           String?
  captureSource        LeadSource                @default(MANUAL)
  status               LeadStatus                @default(CAPTURED)
  qualificationStatus  LeadQualificationStatus   @default(UNQUALIFIED)
  distributionStatus   LeadDistributionStatus    @default(UNASSIGNED)
  score                Int                       @default(0)
  temperature          String?
  firstName            String?
  lastName             String?
  fullName             String?
  email                String?
  phone                String?
  companyName          String?
  jobTitle             String?
  website              String?
  city                 String?
  state                String?
  country              String?
  interest             String?
  notes                String?
  tags                 Json?
  ownerUserId          String?
  estimatedValue       Decimal?                  @db.Decimal(18, 2)
  currency             String                    @default("BRL")
  qualifiedAt          DateTime?
  distributedAt        DateTime?
  lastContactAt        DateTime?
  nextFollowUpAt       DateTime?
  nurturingStartedAt   DateTime?
  convertedAt          DateTime?
  lostAt               DateTime?
  metadata             Json?
  createdByUserId      String?
  updatedByUserId      String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  workspace            Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner                User?                     @relation("LeadOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  activities           LeadActivity[]
  assignments          LeadAssignment[]
  nurtureTouches       LeadNurtureTouch[]
  conversion           LeadConversion?
  integrationEvents    LeadIntegrationEvent[]
  marketingPreferences MarketingContactPreference[]
  marketingEvents      MarketingEvent[]
  marketingAttributions MarketingAttribution[]
  marketingLeadScoreEvents MarketingLeadScoreEvent[]
  marketingCampaignSends MarketingCampaignSend[]
  marketingAutomationEnrollments MarketingAutomationEnrollment[]
  marketingConsentRecords MarketingConsentRecord[]

  @@unique([workspaceId, externalSource, externalId])
  @@index([workspaceId, status, createdAt])
  @@index([workspaceId, qualificationStatus, distributionStatus, createdAt])
  @@index([workspaceId, ownerUserId, nextFollowUpAt])
  @@index([workspaceId, email, phone])
}

model LeadActivity {
  id            String            @id @default(uuid())
  workspaceId   String
  leadId        String
  type          LeadActivityType
  title         String
  description   String?
  payload       Json?
  actorUserId   String?
  occurredAt    DateTime          @default(now())
  createdAt     DateTime          @default(now())
  workspace     Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead          Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actor         User?             @relation("LeadActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, leadId, occurredAt])
  @@index([workspaceId, type, occurredAt])
}

model LeadAssignment {
  id                  String                    @id @default(uuid())
  workspaceId         String
  leadId              String
  fromUserId          String?
  toUserId            String?
  strategy            LeadDistributionStrategy  @default(MANUAL)
  reason              String?
  assignedByUserId    String?
  createdAt           DateTime                  @default(now())
  workspace           Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead                Lead                      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actor               User?                     @relation("LeadAssignmentActor", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, leadId, createdAt])
  @@index([workspaceId, toUserId, createdAt])
}

model LeadNurtureTouch {
  id                 String             @id @default(uuid())
  workspaceId        String
  leadId             String
  status             LeadNurtureStatus  @default(DRAFT)
  channel            String
  templateKey        String?
  subject            String?
  message            String?
  scheduledAt        DateTime?
  sentAt             DateTime?
  respondedAt        DateTime?
  providerMessageId  String?
  errorMessage       String?
  metadata           Json?
  createdByUserId    String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  workspace          Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead               Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actor              User?              @relation("LeadNurtureActor", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, leadId, status, createdAt])
  @@index([workspaceId, scheduledAt])
}

model LeadConversion {
  id                 String              @id @default(uuid())
  workspaceId        String
  leadId             String              @unique
  conversionType     LeadConversionType  @default(CUSTOMER)
  conversionRef      String
  amount             Decimal?            @db.Decimal(18, 2)
  currency           String              @default("BRL")
  notes              String?
  convertedByUserId  String?
  convertedAt        DateTime            @default(now())
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead               Lead                @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actor              User?               @relation("LeadConversionActor", fields: [convertedByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, conversionType, convertedAt])
}

model LeadIntegrationEvent {
  id               String                      @id @default(uuid())
  workspaceId      String?
  leadId           String?
  source           LeadIntegrationSource       @default(GENERIC_WEBHOOK)
  eventType        String
  providerEventId  String?
  idempotencyKey   String                      @unique
  status           LeadIntegrationEventStatus  @default(RECEIVED)
  headers          Json?
  payload          Json
  attempts         Int                         @default(0)
  receivedAt       DateTime                    @default(now())
  processedAt      DateTime?
  lastError        String?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  workspace        Workspace?                  @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  lead             Lead?                       @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, createdAt])
  @@index([source, eventType, createdAt])
}

model MarketingAudienceSegment {
  id                String               @id @default(uuid())
  workspaceId       String
  name              String
  description       String?
  kind              MarketingAudienceType @default(DYNAMIC)
  filters           Json
  isActive          Boolean              @default(true)
  isSystem          Boolean              @default(false)
  lastEvaluatedAt   DateTime?
  estimatedContacts Int?
  createdByUserId   String?
  updatedByUserId   String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  workspace         Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaigns         MarketingCampaign[]
  events            MarketingEvent[]

  @@unique([workspaceId, name])
  @@index([workspaceId, isActive, updatedAt])
}

model MarketingEmailTemplate {
  id                   String                    @id @default(uuid())
  workspaceId          String
  name                 String
  slug                 String
  category             String?
  objective            MarketingCampaignObjective?
  funnelStage          String?
  subject              String
  bodyMarkdown         String
  bodyHtml             String?
  blocks               Json?
  performanceSnapshot  Json?
  isSystem             Boolean                   @default(false)
  isArchived           Boolean                   @default(false)
  createdByUserId      String?
  updatedByUserId      String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  workspace            Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaigns            MarketingCampaign[]
  variants             MarketingCampaignVariant[]
  assets               MarketingContentAsset[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, isArchived, updatedAt])
}

model MarketingSenderProfile {
  id             String                   @id @default(uuid())
  workspaceId    String
  name           String
  fromName       String
  fromEmail      String
  replyToEmail   String?
  providerKey    String                   @default("default")
  domainStatus   String?
  isDefault      Boolean                  @default(false)
  isVerified     Boolean                  @default(false)
  config         Json?
  createdByUserId String?
  updatedByUserId String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  workspace      Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaigns      MarketingCampaign[]
  sends          MarketingCampaignSend[]

  @@unique([workspaceId, fromEmail])
  @@index([workspaceId, isDefault])
}

model MarketingCampaign {
  id                 String                    @id @default(uuid())
  workspaceId        String
  name               String
  description        String?
  objective          MarketingCampaignObjective
  channel            MarketingCampaignChannel  @default(EMAIL)
  status             MarketingCampaignStatus   @default(DRAFT)
  hypothesis         String?
  persona            String?
  icp                String?
  offer              String?
  productRef         String?
  billingContext     String?
  segmentId          String?
  templateId         String?
  senderProfileId    String?
  abTestEnabled      Boolean                   @default(false)
  abTestConfig       Json?
  scheduledAt        DateTime?
  launchedAt         DateTime?
  completedAt        DateTime?
  archivedAt         DateTime?
  approvalRequestedAt DateTime?
  approvedAt         DateTime?
  approvedByUserId   String?
  aiGenerated        Boolean                   @default(false)
  aiContext          Json?
  createdByUserId    String?
  updatedByUserId    String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  workspace          Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  segment            MarketingAudienceSegment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  template           MarketingEmailTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  senderProfile      MarketingSenderProfile?   @relation(fields: [senderProfileId], references: [id], onDelete: SetNull)
  variants           MarketingCampaignVariant[]
  events             MarketingEvent[]
  attributions       MarketingAttribution[]
