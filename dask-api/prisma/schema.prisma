generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum AuditSeverity {
  INFO
  WARNING
  ERROR
}

enum CustomFieldType {
  TEXT
  LONG_TEXT
  NUMBER
  DATE
  DATETIME
  BOOLEAN
  SELECT
  MULTI_SELECT
  USER
}

enum AuthProvider {
  GOOGLE
  MICROSOFT
}

enum WorkspaceKind {
  PERSONAL
  CORPORATE
}

enum SubscriptionPlan {
  PERSONAL
  BUSINESS
}

enum SubscriptionStatus {
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

model User {
  id                       String                    @id @default(uuid())
  email                    String                    @unique
  name                     String
  emailVerified            Boolean                   @default(false)
  passwordHash             String?
  // 0 = legacy plain-bcrypt (pre-migration), 1 = HMAC-SHA256+bcrypt with pepper
  passwordHashVersion      Int                       @default(0)
  loginFailureCount        Int                       @default(0)
  lockedUntil              DateTime?
  preferences              Json?
  // Billing / Stripe
  stripeCustomerId         String?                   @unique
  subscriptionPlan         SubscriptionPlan?
  subscriptionStatus       SubscriptionStatus?
  subscriptionId           String?
  currentPeriodEnd         DateTime?
  hasActiveSubscription    Boolean                   @default(false)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  organizations            OrganizationMembership[]
  teams                    TeamMembership[]
  workspaces               WorkspaceMembership[]
  createdItems             Item[]                    @relation("ItemCreatedBy")
  assignedItems            Item[]                    @relation("ItemAssignee")
  updatedItems             Item[]                    @relation("ItemUpdatedBy")
  comments                 ItemComment[]
  updatedCustomFieldValues CustomFieldValue[]        @relation("CustomFieldValueUpdatedBy")
  updatedViewPlacements    WorkItemViewPlacement[]   @relation("WorkItemViewPlacementUpdatedBy")
  refreshTokens            RefreshToken[]
  resetTokens              PasswordResetToken[]
  verificationTokens       EmailVerificationToken[]
  externalIdentities       ExternalIdentity[]
  subscriptions            Subscription[]
}

model Subscription {
  id                       String             @id @default(uuid())
  userId                   String
  stripeCustomerId         String
  stripeSubscriptionId     String             @unique
  stripeCheckoutSessionId  String?
  planCode                 SubscriptionPlan
  status                   SubscriptionStatus
  currency                 String             @default("brl")
  amount                   Int                // in cents
  interval                 String             @default("month")
  currentPeriodStart       DateTime?
  currentPeriodEnd         DateTime?
  cancelAtPeriodEnd        Boolean            @default(false)
  lastWebhookEvent         String?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  user                     User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeCustomerId])
}

model ExternalIdentity {
  id               String       @id @default(uuid())
  userId           String
  provider         AuthProvider
  providerSubject  String
  providerTenantId String?
  emailAtProvider  String?
  emailVerified    Boolean?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject, providerTenantId])
  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  // familyId links tokens issued from the same login session;
  // reuse of a revoked token triggers revocation of the entire family
  familyId  String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Organization {
  id              String                    @id @default(uuid())
  name            String
  slug            String                    @unique
  settings        Json?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  memberships     OrganizationMembership[]
  teams           Team[]
  workspaces      Workspace[]
}

model OrganizationMembership {
  id              String                    @id @default(uuid())
  organizationId  String
  userId          String
  role            MembershipRole            @default(MEMBER)
  permissions     Json?
  createdAt       DateTime                  @default(now())
  organization    Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model Team {
  id              String                    @id @default(uuid())
  organizationId  String
  name            String
  metadata        Json?
  createdAt       DateTime                  @default(now())
  organization    Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships     TeamMembership[]
}

model TeamMembership {
  id              String                    @id @default(uuid())
  teamId          String
  userId          String
  role            MembershipRole            @default(MEMBER)
  permissions     Json?
  createdAt       DateTime                  @default(now())
  team            Team                      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Workspace {
  id                     String                    @id @default(uuid())
  organizationId         String?
  kind                   WorkspaceKind             @default(CORPORATE)
  name                   String
  key                    String
  config                 Json?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  organization           Organization?             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships            WorkspaceMembership[]
  boards                 Board[]
  templates              BoardTemplate[]
  itemTypes              WorkItemType[]
  workflowStates         WorkflowState[]
  boardColumns           BoardColumn[]
  columnStateMappings    ColumnStateMapping[]
  tagDefinitions         TagDefinition[]
  customFieldDefinitions CustomFieldDefinition[]
  preferences            WorkspacePreferences?
  workItems              Item[]
  automationRules        AutomationRule[]
  automationViews        AutomationView[]
  automationViewColumns  AutomationViewColumn[]
  itemViewPlacements     WorkItemViewPlacement[]
  automationExecutions   AutomationExecution[]

  @@unique([organizationId, key])
}

model WorkspaceMembership {
  id              String                    @id @default(uuid())
  workspaceId     String
  userId          String
  role            MembershipRole            @default(MEMBER)
  permissions     Json?
  createdAt       DateTime                  @default(now())
  workspace       Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model BoardTemplate {
  id              String                    @id @default(uuid())
  workspaceId     String
  name            String
  description     String?
  schema          Json
  rules           Json?
  createdAt       DateTime                  @default(now())
  workspace       Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  boards          Board[]
}

model Board {
  id              String                    @id @default(uuid())
  workspaceId     String
  templateId      String?
  name            String
  description     String?
  config          Json?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  workspace       Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  template        BoardTemplate?            @relation(fields: [templateId], references: [id], onDelete: SetNull)
  columns         ColumnDefinition[]
  items           Item[]
}

model ColumnDefinition {
  id              String                    @id @default(uuid())
  boardId         String
  name            String
  code            String
  position        Int
  settings        Json?
  board           Board                     @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@unique([boardId, code])
}

model WorkItemType {
  id                  String              @id @default(uuid())
  workspaceId         String
  name                String
  slug                String
  description         String?
  color               String
  icon                String?
  position            Int
  isActive            Boolean             @default(true)
  usageRules          Json?
  acceptsParent       Boolean             @default(true)
  acceptsChecklist    Boolean             @default(true)
  acceptsDueDate      Boolean             @default(true)
  acceptsAssignee     Boolean             @default(true)
  acceptsTags         Boolean             @default(true)
  acceptsCustomFields Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  workspace           Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  items               Item[]
  customFieldScopes   CustomFieldScope[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, isActive])
}

model WorkflowState {
  id            String               @id @default(uuid())
  workspaceId   String
  name          String
  slug          String
  category      String?
  color         String
  position      Int
  isActive      Boolean              @default(true)
  isTerminal    Boolean              @default(false)
  isEditable    Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  workspace     Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  items         Item[]
  columnMapping ColumnStateMapping[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, isActive])
}

model BoardColumn {
  id            String               @id @default(uuid())
  workspaceId   String
  name          String
  slug          String
  position      Int
  wipLimit      Int?
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  workspace     Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  items         Item[]
  stateMappings ColumnStateMapping[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, isActive])
}

model ColumnStateMapping {
  id          String       @id @default(uuid())
  workspaceId String
  columnId    String
  stateId     String
  position    Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  column      BoardColumn  @relation(fields: [columnId], references: [id], onDelete: Cascade)
  state       WorkflowState @relation(fields: [stateId], references: [id], onDelete: Cascade)

  @@unique([columnId, stateId])
  @@index([workspaceId, columnId])
  @@index([workspaceId, stateId])
}

model TagDefinition {
  id          String       @id @default(uuid())
  workspaceId String
  name        String
  slug        String
  color       String
  description String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  itemTags    WorkItemTag[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, isActive])
}

model WorkspacePreferences {
  id                  String     @id @default(uuid())
  workspaceId         String     @unique
  defaultBoardMode    String     @default("dev")
  dateFormat          String     @default("dd/mm/yyyy")
  visibleCardFieldIds Json?
  settings            Json?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  workspace           Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model CustomFieldDefinition {
  id            String              @id @default(uuid())
  workspaceId   String
  name          String
  slug          String
  description   String?
  type          CustomFieldType
  required      Boolean             @default(false)
  position      Int
  isActive      Boolean             @default(true)
  settings      Json?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  workspace     Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  options       CustomFieldOption[]
  values        CustomFieldValue[]
  scopes        CustomFieldScope[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, isActive])
}

model CustomFieldOption {
  id          String                 @id @default(uuid())
  fieldId     String
  label       String
  value       String
  color       String?
  position    Int
  isActive    Boolean                @default(true)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  field       CustomFieldDefinition  @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([fieldId, value])
  @@index([fieldId, position])
}

model CustomFieldScope {
  id        String                @id @default(uuid())
  fieldId   String
  typeId    String
  createdAt DateTime              @default(now())
  field     CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  type      WorkItemType          @relation(fields: [typeId], references: [id], onDelete: Cascade)

  @@unique([fieldId, typeId])
}

model Item {
  id                String              @id @default(uuid())
  boardId           String
  workspaceId       String
  columnId          String?
  boardColumnId     String?
  type              String              @default("task")
  typeId            String?
  stateId           String?
  title             String
  description       String?
  status            String              @default("backlog")
  fields            Json?
  metadata          Json?
  checklist         Json?
  assigneeId        String?
  parentId          String?
  dueDate           DateTime?
  position          Int                 @default(0)
  createdBy         String
  updatedBy         String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  board             Board               @relation(fields: [boardId], references: [id], onDelete: Cascade)
  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  boardColumn       BoardColumn?        @relation(fields: [boardColumnId], references: [id], onDelete: SetNull)
  typeDefinition    WorkItemType?       @relation(fields: [typeId], references: [id], onDelete: SetNull)
  workflowState     WorkflowState?      @relation(fields: [stateId], references: [id], onDelete: SetNull)
  creator           User                @relation("ItemCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  assignee          User?               @relation("ItemAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  updater           User?               @relation("ItemUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  parent            Item?               @relation("ItemParent", fields: [parentId], references: [id], onDelete: SetNull)
  children          Item[]              @relation("ItemParent")
  comments          ItemComment[]
  attachments       ItemAttachment[]
  history           ItemHistory[]
  searchDocuments   SearchDocument[]
  customFieldValues CustomFieldValue[]
  tags              WorkItemTag[]
  viewPlacements    WorkItemViewPlacement[]

  @@index([workspaceId, typeId])
  @@index([workspaceId, stateId])
  @@index([workspaceId, boardColumnId])
  @@index([workspaceId, assigneeId])
  @@index([parentId])
}

model CustomFieldValue {
  id        String                @id @default(uuid())
  fieldId   String
  itemId    String
  value     Json
  updatedBy String?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  field     CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  item      Item                  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  updater   User?                 @relation("CustomFieldValueUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@unique([fieldId, itemId])
  @@index([itemId])
}

model WorkItemTag {
  id        String        @id @default(uuid())
  itemId    String
  tagId     String
  createdAt DateTime      @default(now())
  item      Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag       TagDefinition @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([itemId, tagId])
  @@index([tagId])
}

model ItemComment {
  id              String                    @id @default(uuid())
  itemId          String
  authorId        String
  content         String
  metadata        Json?
  createdAt       DateTime                  @default(now())
  item            Item                      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  author          User                      @relation(fields: [authorId], references: [id], onDelete: Restrict)
}

model ItemAttachment {
  id              String                    @id @default(uuid())
  itemId          String
  fileName        String
  url             String
  metadata        Json?
  createdAt       DateTime                  @default(now())
  item            Item                      @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model ItemHistory {
  id              String                    @id @default(uuid())
  itemId          String
  eventName       String
  payload         Json
  createdAt       DateTime                  @default(now())
  item            Item                      @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model AutomationRule {
  id              String                    @id @default(uuid())
  workspaceId     String
  name            String
  description     String?
  triggerType     String
  trigger         Json
  conditions      Json?
  actions         Json
  priority        Int                       @default(100)
  version         Int                       @default(1)
  enabled         Boolean                   @default(true)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  workspace       Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  executions      AutomationExecution[]

  @@index([workspaceId, enabled, triggerType, priority])
}

model AutomationExecution {
  id          String         @id @default(uuid())
  workspaceId String
  ruleId      String?
  eventName   String
  eventId     String?
  status      String
  attempts    Int            @default(0)
  context     Json?
  error       String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  rule        AutomationRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([ruleId, createdAt])
}

model AutomationView {
  id          String                 @id @default(uuid())
  workspaceId String
  key         String
  name        String
  description String?
  position    Int                    @default(0)
  isSystem    Boolean                @default(false)
  isActive    Boolean                @default(true)
  settings    Json?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  workspace   Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  columns     AutomationViewColumn[]
  placements  WorkItemViewPlacement[]

  @@unique([workspaceId, key])
  @@index([workspaceId, isActive, position])
}

model AutomationViewColumn {
  id          String               @id @default(uuid())
  workspaceId String
  viewId      String
  key         String
  name        String
  description String?
  color       String
  position    Int                  @default(0)
  isActive    Boolean              @default(true)
  isTerminal  Boolean              @default(false)
  settings    Json?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  workspace   Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  view        AutomationView       @relation(fields: [viewId], references: [id], onDelete: Cascade)
  placements  WorkItemViewPlacement[]

  @@unique([viewId, key])
  @@index([workspaceId, viewId, isActive, position])
}

model WorkItemViewPlacement {
  id          String                @id @default(uuid())
  workspaceId String
  itemId      String
  viewId      String
  columnId    String
  position    Int                   @default(0)
  metadata    Json?
  updatedBy   String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  workspace   Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  item        Item                  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  view        AutomationView        @relation(fields: [viewId], references: [id], onDelete: Cascade)
  column      AutomationViewColumn  @relation(fields: [columnId], references: [id], onDelete: Cascade)
  updater     User?                 @relation("WorkItemViewPlacementUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@unique([itemId, viewId])
  @@index([workspaceId, viewId, columnId, position])
}

model SearchDocument {
  id              String                    @id @default(uuid())
  itemId          String
  workspaceId     String
  boardId         String
  content         String
  metadata        Json?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  item            Item                      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([workspaceId, boardId])
}

model DomainOutbox {
  id              String                    @id @default(uuid())
  eventName       String
  aggregateType   String
  aggregateId     String
  payload         Json
  occurredAt      DateTime
  processedAt     DateTime?
  retries         Int                       @default(0)
  createdAt       DateTime                  @default(now())
}

model AuditEvent {
  id              String                    @id @default(uuid())
  eventName       String
  severity        AuditSeverity             @default(INFO)
  actorId         String?
  workspaceId     String?
  metadata        Json?
  happenedAt      DateTime                  @default(now())
}
