generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum AuditSeverity {
  INFO
  WARNING
  ERROR
}

enum CustomFieldType {
  TEXT
  LONG_TEXT
  NUMBER
  DATE
  DATETIME
  BOOLEAN
  SELECT
  MULTI_SELECT
  USER
}

enum AuthProvider {
  GOOGLE
  MICROSOFT
}

enum WorkspaceKind {
  PERSONAL
  CORPORATE
}

enum SubscriptionPlan {
  PERSONAL
  BUSINESS
}

enum SubscriptionStatus {
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

enum ConnectPaymentOrderStatus {
  DRAFT
  CHECKOUT_OPEN
  CHECKOUT_COMPLETED
  PENDING
  PAID
  FAILED
  CANCELED
  REFUNDED
}

enum ConnectCatalogItemKind {
  PRODUCT
  SERVICE
}

enum ConnectCatalogBillingType {
  ONE_TIME
  SUBSCRIPTION
}

enum ConnectCatalogRecurringInterval {
  DAY
  WEEK
  MONTH
  YEAR
}

enum FiscalProvider {
  FOCUS
}

enum FiscalDirection {
  OUTBOUND
  INBOUND
}

enum FiscalDocumentType {
  NFE
  NFSE
}

enum FiscalDocumentOrigin {
  MANUAL_PRODUCT
  MANUAL_SERVICE
  CATALOG_PRODUCT
  CATALOG_SERVICE
  STRIPE_PAYMENT
  STRIPE_SUBSCRIPTION
  EXTERNAL_RECEIVED_NFE
  EXTERNAL_RECEIVED_NFSE
}

enum FiscalSourceSystem {
  INTERNAL
  STRIPE
  FOCUS
  MDE
  NFSER
}

enum FiscalDocumentStatus {
  DRAFT
  READY_TO_ISSUE
  ISSUING
  AUTHORIZED
  PROCESSING
  PENDING_REVIEW
  REJECTED
  CANCELLED
  FAILED
  RECEIVED
  MANIFEST_PENDING
  MANIFESTED
  SYNCED
}

enum FiscalIssueStatus {
  NOT_STARTED
  PROCESSING
  AUTHORIZED
  REJECTED
  CANCELLED
  FAILED
}

enum FiscalPartyRole {
  EMITTER
  RECIPIENT
  TAKER
  SUPPLIER
}

enum FiscalReceivedType {
  NFE_MDE
  NFSE_NFSER
}

enum FiscalReceivedStatus {
  RECEIVED
  MANIFEST_PENDING
  MANIFESTED
  SYNCED
  FAILED
}

enum FiscalSyncType {
  RECEIVED_NFE
  RECEIVED_NFSE
  PENDING_RECONCILIATION
  OUTBOUND_STATUS
}

enum FiscalSyncTrigger {
  MANUAL
  SCHEDULED
  WEBHOOK
  RETRY
}

enum FiscalSyncStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

enum FiscalWebhookSource {
  FOCUS
  STRIPE
}

enum FiscalWebhookStatus {
  RECEIVED
  PROCESSED
  FAILED
  DUPLICATE
}

enum FiscalCatalogItemType {
  PRODUCT
  SERVICE
}

enum FiscalDraftStatus {
  DRAFT
  READY
  ISSUED
  CANCELLED
}

enum FiscalIntegrationDirection {
  OUTBOUND
  INBOUND
}

enum FiscalIntegrationStatus {
  SUCCESS
  ERROR
}

model User {
  id                       String                    @id @default(uuid())
  email                    String                    @unique
  name                     String
  emailVerified            Boolean                   @default(false)
  isPlatformAdmin          Boolean                   @default(false)
  passwordHash             String?
  // 0 = legacy plain-bcrypt (pre-migration), 1 = HMAC-SHA256+bcrypt with pepper
  passwordHashVersion      Int                       @default(0)
  loginFailureCount        Int                       @default(0)
  lockedUntil              DateTime?
  preferences              Json?
  // Billing / Stripe
  stripeCustomerId         String?                   @unique
  subscriptionPlan         SubscriptionPlan?
  subscriptionStatus       SubscriptionStatus?
  subscriptionId           String?
  currentPeriodEnd         DateTime?
  hasActiveSubscription    Boolean                   @default(false)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  organizations            OrganizationMembership[]
  teams                    TeamMembership[]
  workspaces               WorkspaceMembership[]
  createdItems             Item[]                    @relation("ItemCreatedBy")
  assignedItems            Item[]                    @relation("ItemAssignee")
  updatedItems             Item[]                    @relation("ItemUpdatedBy")
  comments                 ItemComment[]
  updatedCustomFieldValues CustomFieldValue[]        @relation("CustomFieldValueUpdatedBy")
  updatedViewPlacements    WorkItemViewPlacement[]   @relation("WorkItemViewPlacementUpdatedBy")
  refreshTokens            RefreshToken[]
  resetTokens              PasswordResetToken[]
  verificationTokens       EmailVerificationToken[]
  externalIdentities       ExternalIdentity[]
  subscriptions            Subscription[]
  sentWorkspaceInvites     WorkspaceInvite[]        @relation("WorkspaceInviteSentBy")
  acceptedWorkspaceInvites WorkspaceInvite[]        @relation("WorkspaceInviteAcceptedBy")
}

model Subscription {
  id                       String             @id @default(uuid())
  userId                   String
  stripeCustomerId         String
  stripeSubscriptionId     String             @unique
  stripeCheckoutSessionId  String?
  planCode                 SubscriptionPlan
  status                   SubscriptionStatus
  currency                 String             @default("brl")
  amount                   Int                // in cents
  interval                 String             @default("month")
  currentPeriodStart       DateTime?
  currentPeriodEnd         DateTime?
  cancelAtPeriodEnd        Boolean            @default(false)
  lastWebhookEvent         String?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  user                     User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeCustomerId])
}

model ExternalIdentity {
  id               String       @id @default(uuid())
  userId           String
  provider         AuthProvider
  providerSubject  String
  providerTenantId String?
  emailAtProvider  String?
  emailVerified    Boolean?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject, providerTenantId])
  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  // familyId links tokens issued from the same login session;
  // reuse of a revoked token triggers revocation of the entire family
  familyId  String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Organization {
  id              String                    @id @default(uuid())
  name            String
  slug            String                    @unique
  settings        Json?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  memberships     OrganizationMembership[]
  teams           Team[]
  workspaces      Workspace[]
}

model OrganizationMembership {
  id              String                    @id @default(uuid())
  organizationId  String
  userId          String
  role            MembershipRole            @default(MEMBER)
  permissions     Json?
  createdAt       DateTime                  @default(now())
  organization    Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model Team {
  id              String                    @id @default(uuid())
  organizationId  String
  name            String
  metadata        Json?
  createdAt       DateTime                  @default(now())
  organization    Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships     TeamMembership[]
}

model TeamMembership {
  id              String                    @id @default(uuid())
  teamId          String
  userId          String
  role            MembershipRole            @default(MEMBER)
  permissions     Json?
  createdAt       DateTime                  @default(now())
  team            Team                      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model Workspace {
  id                     String                    @id @default(uuid())
  organizationId         String?
  kind                   WorkspaceKind             @default(CORPORATE)
  name                   String
  key                    String
  config                 Json?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  organization           Organization?             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships            WorkspaceMembership[]
  boards                 Board[]
  templates              BoardTemplate[]
  itemTypes              WorkItemType[]
  workflowStates         WorkflowState[]
  boardColumns           BoardColumn[]
  columnStateMappings    ColumnStateMapping[]
  tagDefinitions         TagDefinition[]
  customFieldDefinitions CustomFieldDefinition[]
  preferences            WorkspacePreferences?
  workItems              Item[]
  automationRules        AutomationRule[]
  automationViews        AutomationView[]
  automationViewColumns  AutomationViewColumn[]
  itemViewPlacements     WorkItemViewPlacement[]
  automationExecutions   AutomationExecution[]
  aiAgents               AIAgent[]
  aiAgentRuns            AIAgentRun[]
  invites                WorkspaceInvite[]
  documents              WorkspaceDocument[]
  workItemDocumentLinks  WorkItemDocumentLink[]
  connectPaymentOrders   ConnectPaymentOrder[]
  connectCatalogItems    ConnectCatalogItem[]
  fiscalCompanyConfigs   FiscalCompanyConfig[]
  fiscalDocuments        FiscalDocument[]
  fiscalEmissionDrafts   FiscalEmissionDraft[]
  fiscalReceivedDocuments FiscalReceivedDocument[]
  fiscalSyncRuns         FiscalSyncRun[]
  fiscalWebhookEvents    FiscalWebhookEvent[]
  fiscalIntegrationLogs  FiscalIntegrationLog[]
  fiscalCatalogProfiles  FiscalCatalogProfile[]
  fiscalOperationTemplates FiscalOperationTemplate[]

  @@unique([organizationId, key])
}

model WorkspaceDocument {
  id          String    @id @default(uuid())
  workspaceId String
  title       String
  content     String
  position    Int       @default(0)
  createdBy   String
  updatedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  itemLinks   WorkItemDocumentLink[]

  @@index([workspaceId, updatedAt])
  @@index([workspaceId, position])
}

model ConnectPaymentOrder {
  id                    String                    @id @default(uuid())
  workspaceId           String
  createdByUserId       String
  stripeConnectAccountId String
  stripeCheckoutSessionId String?                 @unique
  stripePaymentIntentId String?                   @unique
  amount                Int
  currency              String                    @default("brl")
  description           String
  customerEmail         String?
  applicationFeeAmount  Int
  status                ConnectPaymentOrderStatus @default(DRAFT)
  statusReason          String?
  metadata              Json?
  checkoutUrl           String?
  lastWebhookEvent      String?
  paidAt                DateTime?
  failedAt              DateTime?
  canceledAt            DateTime?
  refundedAt            DateTime?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  workspace             Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([status, createdAt])
  @@index([stripeConnectAccountId, createdAt])
}

model ConnectCatalogItem {
  id          String                 @id @default(uuid())
  workspaceId String
  createdByUserId String
  kind        ConnectCatalogItemKind @default(SERVICE)
  billingType ConnectCatalogBillingType @default(ONE_TIME)
  recurringInterval ConnectCatalogRecurringInterval?
  recurringIntervalCount Int?
  name        String
  description String?
  amount      Int
  currency    String                 @default("brl")
  stripeConnectAccountId String?
  stripeProductId String?            @unique
  stripePriceId String?              @unique
  isActive    Boolean                @default(true)
  metadata    Json?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  workspace   Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, isActive, createdAt])
  @@index([workspaceId, stripeConnectAccountId, createdAt])
}

model FiscalCompanyConfig {
  id                      String         @id @default(uuid())
  workspaceId             String
  workspaceBusinessId     String?
  provider                FiscalProvider @default(FOCUS)
  displayName             String
  legalName               String
  cnpj                    String
  stateRegistration       String?
  municipalRegistration   String?
  taxRegime               String?
  focusToken              String
  focusEnvironment        String         @default("homologacao")
  focusCompanyReference   String?
  focusWebhookSecret      String?
  emitAutomatically       Boolean        @default(false)
  stripePolicy            String         @default("assisted_one_click")
  defaultSerie            String?
  defaultNatureOperation  String?
  fallbackRules           Json?
  syncConfig              Json?
  metadata                Json?
  createdByUserId         String?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  workspace               Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  documents               FiscalDocument[]
  drafts                  FiscalEmissionDraft[]
  receivedDocuments       FiscalReceivedDocument[]
  syncRuns                FiscalSyncRun[]
  integrationLogs         FiscalIntegrationLog[]

  @@unique([workspaceId, cnpj])
  @@index([workspaceId, workspaceBusinessId, createdAt])
}

model FiscalDocument {
  id                      String                @id @default(uuid())
  workspaceId             String
  workspaceBusinessId     String?
  companyConfigId         String?
  internalReference       String
  provider                FiscalProvider        @default(FOCUS)
  direction               FiscalDirection
  documentType            FiscalDocumentType
  origin                  FiscalDocumentOrigin
  sourceSystem            FiscalSourceSystem    @default(INTERNAL)
  status                  FiscalDocumentStatus  @default(DRAFT)
  issueStatus             FiscalIssueStatus     @default(NOT_STARTED)
  focusStatus             String?
  operationStatus         String?
  customerId              String?
  supplierId              String?
  saleId                  String?
  stripeSessionId         String?
  stripePaymentIntentId   String?
  stripeChargeId          String?
  stripeAccountId         String?
  focusReference          String?
  focusDocumentId         String?
  number                  String?
  series                  String?
  amountSubtotal          Decimal?              @db.Decimal(18, 4)
  amountDiscount          Decimal?              @db.Decimal(18, 4)
  amountTotal             Decimal?              @db.Decimal(18, 4)
  currency                String                @default("BRL")
  issuedAt                DateTime?
  authorizedAt            DateTime?
  cancelledAt             DateTime?
  xmlUrl                  String?
  pdfUrl                  String?
  xmlStorageRef           String?
  pdfStorageRef           String?
  requestPayloadSnapshot  Json?
  responsePayloadSnapshot Json?
  providerPayloadRaw      Json?
  metadata                Json?
  lastSyncAt              DateTime?
  lastError               String?
  createdByUserId         String?
  updatedByUserId         String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  workspace               Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  companyConfig           FiscalCompanyConfig?  @relation(fields: [companyConfigId], references: [id], onDelete: SetNull)
  items                   FiscalDocumentItem[]
  parties                 FiscalParty[]
  integrationLogs         FiscalIntegrationLog[]

  @@unique([workspaceId, internalReference])
  @@index([workspaceId, workspaceBusinessId, direction, documentType, createdAt])
  @@index([workspaceId, status, issueStatus, createdAt])
  @@index([workspaceId, saleId, stripeSessionId])
  @@index([focusReference, focusDocumentId])
}

model FiscalDocumentItem {
  id                    String         @id @default(uuid())
  documentId            String
  itemType              FiscalCatalogItemType
  sourceType            String?
  catalogProfileId      String?
  sku                   String?
  name                  String
  descriptionCommercial String?
  descriptionFiscal     String?
  quantity              Decimal        @db.Decimal(18, 4)
  unit                  String?
  unitPrice             Decimal        @db.Decimal(18, 4)
  discountAmount        Decimal?       @db.Decimal(18, 4)
  totalAmount           Decimal        @db.Decimal(18, 4)
  taxConfigSnapshot     Json?
  metadata              Json?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  document              FiscalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, createdAt])
}

model FiscalParty {
  id             String         @id @default(uuid())
  documentId     String
  role           FiscalPartyRole
  name           String
  legalName      String?
  cnpjCpf        String
  stateRegistration String?
  municipalRegistration String?
  email          String?
  phone          String?
  address        Json?
  metadata       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  document       FiscalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, role])
  @@index([cnpjCpf])
}

model FiscalEmissionDraft {
  id                  String                @id @default(uuid())
  workspaceId         String
  workspaceBusinessId String?
  companyConfigId     String?
  status              FiscalDraftStatus     @default(DRAFT)
  documentType        FiscalDocumentType
  origin              FiscalDocumentOrigin
  saleId              String?
  stripeSessionId     String?
  stripePaymentIntentId String?
  emitAfterPayment    Boolean               @default(false)
  autoIssueEligible   Boolean               @default(false)
  payload             Json
  suggestion          Json?
  createdByUserId     String?
  issuedDocumentId    String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  workspace           Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  companyConfig       FiscalCompanyConfig?  @relation(fields: [companyConfigId], references: [id], onDelete: SetNull)

  @@index([workspaceId, workspaceBusinessId, status, createdAt])
  @@index([workspaceId, saleId, stripeSessionId])
}

model FiscalReceivedDocument {
  id                  String               @id @default(uuid())
  workspaceId         String
  workspaceBusinessId String?
  companyConfigId     String?
  type                FiscalReceivedType
  status              FiscalReceivedStatus @default(RECEIVED)
  manifestationStatus String?
  externalKey         String
  providerReference   String?
  focusReference      String?
  issuerName          String?
  issuerDocument      String?
  recipientDocument   String?
  amountTotal         Decimal?             @db.Decimal(18, 4)
  issuedAt            DateTime?
  receivedAt          DateTime?
  xmlUrl              String?
  pdfUrl              String?
  payload             Json?
  supplierId          String?
  costCenterId        String?
  categoryId          String?
  financialEntryId    String?
  purchaseId          String?
  mappedDocumentId    String?
  lastSyncAt          DateTime?
  lastError           String?
  metadata            Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  workspace           Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  companyConfig       FiscalCompanyConfig? @relation(fields: [companyConfigId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, type, externalKey])
  @@index([workspaceId, workspaceBusinessId, type, status, createdAt])
  @@index([workspaceId, manifestationStatus])
}

model FiscalSyncRun {
  id                String            @id @default(uuid())
  workspaceId       String
  workspaceBusinessId String?
  companyConfigId   String?
  syncType          FiscalSyncType
  trigger           FiscalSyncTrigger
  status            FiscalSyncStatus  @default(RUNNING)
  startedAt         DateTime          @default(now())
  finishedAt        DateTime?
  processedCount    Int               @default(0)
  createdCount      Int               @default(0)
  updatedCount      Int               @default(0)
  failedCount       Int               @default(0)
  requestSnapshot   Json?
  responseSnapshot  Json?
  lastError         String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  workspace         Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  companyConfig     FiscalCompanyConfig? @relation(fields: [companyConfigId], references: [id], onDelete: SetNull)

  @@index([workspaceId, workspaceBusinessId, syncType, status, startedAt])
}

model FiscalWebhookEvent {
  id                String              @id @default(uuid())
  workspaceId       String?
  source            FiscalWebhookSource
  providerEventId   String?
  eventType         String
  idempotencyKey    String              @unique
  status            FiscalWebhookStatus @default(RECEIVED)
  headers           Json?
  payload           Json
  signature         String?
  attempts          Int                 @default(0)
  processedAt       DateTime?
  lastError         String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  workspace         Workspace?          @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([source, eventType, createdAt])
  @@index([workspaceId, status, createdAt])
}

model FiscalIntegrationLog {
  id                String                    @id @default(uuid())
  workspaceId       String
  companyConfigId   String?
  documentId        String?
  system            FiscalWebhookSource
  direction         FiscalIntegrationDirection
  operation         String
  status            FiscalIntegrationStatus
  correlationId     String?
  httpStatus        Int?
  requestPayload    Json?
  responsePayload   Json?
  errorMessage      String?
  createdAt         DateTime                  @default(now())
  workspace         Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  companyConfig     FiscalCompanyConfig?      @relation(fields: [companyConfigId], references: [id], onDelete: SetNull)
  document          FiscalDocument?           @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@index([workspaceId, system, status, createdAt])
  @@index([documentId, createdAt])
}

model FiscalCatalogProfile {
  id                    String                @id @default(uuid())
  workspaceId           String
  workspaceBusinessId   String?
  itemType              FiscalCatalogItemType
  name                  String
  descriptionCommercial String?
  descriptionFiscal     String?
  sku                   String?
  unit                  String?
  defaultValue          Decimal?              @db.Decimal(18, 4)
  ncm                   String?
  serviceCode           String?
  cnae                  String?
  lcItem                String?
  cfopDefault           String?
  operationNature       String?
  taxConfig             Json?
  isActive              Boolean               @default(true)
  metadata              Json?
  createdByUserId       String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  workspace             Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, workspaceBusinessId, itemType, isActive, createdAt])
  @@index([workspaceId, sku])
}

model FiscalOperationTemplate {
  id                  String             @id @default(uuid())
  workspaceId         String
  workspaceBusinessId String?
  name                String
  documentType        FiscalDocumentType
  itemType            FiscalCatalogItemType?
  serie               String?
  natureOperation     String?
  cfop                String?
  taxDefaults         Json?
  notes               String?
  isDefault           Boolean            @default(false)
  isActive            Boolean            @default(true)
  createdByUserId     String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  workspace           Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, workspaceBusinessId, documentType, isActive, createdAt])
}

model WorkItemDocumentLink {
  id          String            @id @default(uuid())
  workspaceId String
  itemId      String
  documentId  String
  linkedBy    String
  createdAt   DateTime          @default(now())
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  item        Item              @relation(fields: [itemId], references: [id], onDelete: Cascade)
  document    WorkspaceDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([itemId, documentId])
  @@index([workspaceId, itemId, createdAt])
  @@index([workspaceId, documentId, createdAt])
}

model WorkspaceInvite {
  id               String         @id @default(uuid())
  workspaceId      String
  email            String
  role             MembershipRole @default(MEMBER)
  tokenHash        String         @unique
  invitedByUserId  String
  acceptedByUserId String?
  expiresAt        DateTime
  sentAt           DateTime       @default(now())
  acceptedAt       DateTime?
  revokedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  workspace        Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy        User           @relation("WorkspaceInviteSentBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  acceptedBy       User?          @relation("WorkspaceInviteAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId, email])
  @@index([workspaceId, expiresAt, revokedAt, acceptedAt])
}

model WorkspaceMembership {
  id              String                    @id @default(uuid())
  workspaceId     String
  userId          String
  role            MembershipRole            @default(MEMBER)
  permissions     Json?
  createdAt       DateTime                  @default(now())
  workspace       Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user            User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

model BoardTemplate {
  id              String                    @id @default(uuid())
  workspaceId     String
  name            String
  description     String?
  schema          Json
  rules           Json?
  createdAt       DateTime                  @default(now())
  workspace       Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  boards          Board[]
}

model Board {
  id              String                    @id @default(uuid())
  workspaceId     String
  templateId      String?
  name            String
  description     String?
  config          Json?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  workspace       Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  template        BoardTemplate?            @relation(fields: [templateId], references: [id], onDelete: SetNull)
  columns         ColumnDefinition[]
  items           Item[]
}

model ColumnDefinition {
  id              String                    @id @default(uuid())
  boardId         String
  name            String
  code            String
  position        Int
  settings        Json?
  board           Board                     @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@unique([boardId, code])
}

model WorkItemType {
  id                  String              @id @default(uuid())
  workspaceId         String
  name                String
  slug                String
  description         String?
  color               String
  icon                String?
  position            Int
  isActive            Boolean             @default(true)
  usageRules          Json?
  acceptsParent       Boolean             @default(true)
  acceptsChecklist    Boolean             @default(true)
  acceptsDueDate      Boolean             @default(true)
  acceptsAssignee     Boolean             @default(true)
  acceptsTags         Boolean             @default(true)
  acceptsCustomFields Boolean             @default(true)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  workspace           Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  items               Item[]
  customFieldScopes   CustomFieldScope[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, isActive])
}

model WorkflowState {
  id            String               @id @default(uuid())
  workspaceId   String
  name          String
  slug          String
  category      String?
  color         String
  position      Int
  isActive      Boolean              @default(true)
  isTerminal    Boolean              @default(false)
  isEditable    Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  workspace     Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  items         Item[]
  columnMapping ColumnStateMapping[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, isActive])
}

model BoardColumn {
  id            String               @id @default(uuid())
  workspaceId   String
  name          String
  slug          String
  position      Int
  wipLimit      Int?
  isActive      Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  workspace     Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  items         Item[]
  stateMappings ColumnStateMapping[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, isActive])
}

model ColumnStateMapping {
  id          String       @id @default(uuid())
  workspaceId String
  columnId    String
  stateId     String
  position    Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  column      BoardColumn  @relation(fields: [columnId], references: [id], onDelete: Cascade)
  state       WorkflowState @relation(fields: [stateId], references: [id], onDelete: Cascade)

  @@unique([columnId, stateId])
  @@index([workspaceId, columnId])
  @@index([workspaceId, stateId])
}

model TagDefinition {
  id          String       @id @default(uuid())
  workspaceId String
  name        String
  slug        String
  color       String
  description String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  itemTags    WorkItemTag[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, isActive])
}

model WorkspacePreferences {
  id                  String     @id @default(uuid())
  workspaceId         String     @unique
  defaultBoardMode    String     @default("dev")
  dateFormat          String     @default("dd/mm/yyyy")
  visibleCardFieldIds Json?
  settings            Json?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  workspace           Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model CustomFieldDefinition {
  id            String              @id @default(uuid())
  workspaceId   String
  name          String
  slug          String
  description   String?
  type          CustomFieldType
  required      Boolean             @default(false)
  position      Int
  isActive      Boolean             @default(true)
  settings      Json?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  workspace     Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  options       CustomFieldOption[]
  values        CustomFieldValue[]
  scopes        CustomFieldScope[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, isActive])
}

model CustomFieldOption {
  id          String                 @id @default(uuid())
  fieldId     String
  label       String
  value       String
  color       String?
  position    Int
  isActive    Boolean                @default(true)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  field       CustomFieldDefinition  @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([fieldId, value])
  @@index([fieldId, position])
}

model CustomFieldScope {
  id        String                @id @default(uuid())
  fieldId   String
  typeId    String
  createdAt DateTime              @default(now())
  field     CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  type      WorkItemType          @relation(fields: [typeId], references: [id], onDelete: Cascade)

  @@unique([fieldId, typeId])
}

model Item {
  id                String              @id @default(uuid())
  boardId           String
  workspaceId       String
  columnId          String?
  boardColumnId     String?
  type              String              @default("task")
  typeId            String?
  stateId           String?
  title             String
  description       String?
  status            String              @default("backlog")
  fields            Json?
  metadata          Json?
  checklist         Json?
  assigneeId        String?
  parentId          String?
  dueDate           DateTime?
  position          Int                 @default(0)
  createdBy         String
  updatedBy         String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  board             Board               @relation(fields: [boardId], references: [id], onDelete: Cascade)
  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  boardColumn       BoardColumn?        @relation(fields: [boardColumnId], references: [id], onDelete: SetNull)
  typeDefinition    WorkItemType?       @relation(fields: [typeId], references: [id], onDelete: SetNull)
  workflowState     WorkflowState?      @relation(fields: [stateId], references: [id], onDelete: SetNull)
  creator           User                @relation("ItemCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  assignee          User?               @relation("ItemAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  updater           User?               @relation("ItemUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  parent            Item?               @relation("ItemParent", fields: [parentId], references: [id], onDelete: SetNull)
  children          Item[]              @relation("ItemParent")
  comments          ItemComment[]
  attachments       ItemAttachment[]
  history           ItemHistory[]
  searchDocuments   SearchDocument[]
  documentLinks     WorkItemDocumentLink[]
  customFieldValues CustomFieldValue[]
  tags              WorkItemTag[]
  viewPlacements    WorkItemViewPlacement[]
  aiAgentRuns       AIAgentRun[]

  @@index([workspaceId, typeId])
  @@index([workspaceId, stateId])
  @@index([workspaceId, boardColumnId])
  @@index([workspaceId, assigneeId])
  @@index([parentId])
}

model CustomFieldValue {
  id        String                @id @default(uuid())
  fieldId   String
  itemId    String
  value     Json
  updatedBy String?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  field     CustomFieldDefinition @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  item      Item                  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  updater   User?                 @relation("CustomFieldValueUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@unique([fieldId, itemId])
  @@index([itemId])
}

model WorkItemTag {
  id        String        @id @default(uuid())
  itemId    String
  tagId     String
  createdAt DateTime      @default(now())
  item      Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag       TagDefinition @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([itemId, tagId])
  @@index([tagId])
}

model ItemComment {
  id              String                    @id @default(uuid())
  itemId          String
  authorId        String
  content         String
  metadata        Json?
  createdAt       DateTime                  @default(now())
  item            Item                      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  author          User                      @relation(fields: [authorId], references: [id], onDelete: Restrict)
}

model ItemAttachment {
  id              String                    @id @default(uuid())
  itemId          String
  fileName        String
  url             String
  metadata        Json?
  createdAt       DateTime                  @default(now())
  item            Item                      @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model ItemHistory {
  id              String                    @id @default(uuid())
  itemId          String
  eventName       String
  payload         Json
  createdAt       DateTime                  @default(now())
  item            Item                      @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model AutomationRule {
  id              String                    @id @default(uuid())
  workspaceId     String
  name            String
  description     String?
  triggerType     String
  trigger         Json
  conditions      Json?
  actions         Json
  priority        Int                       @default(100)
  version         Int                       @default(1)
  enabled         Boolean                   @default(true)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  workspace       Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  executions      AutomationExecution[]

  @@index([workspaceId, enabled, triggerType, priority])
}

model AutomationExecution {
  id          String         @id @default(uuid())
  workspaceId String
  ruleId      String?
  eventName   String
  eventId     String?
  status      String
  attempts    Int            @default(0)
  context     Json?
  error       String?
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  rule        AutomationRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([ruleId, createdAt])
}

model AutomationView {
  id          String                 @id @default(uuid())
  workspaceId String
  key         String
  name        String
  description String?
  position    Int                    @default(0)
  isSystem    Boolean                @default(false)
  isActive    Boolean                @default(true)
  settings    Json?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  workspace   Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  columns     AutomationViewColumn[]
  placements  WorkItemViewPlacement[]

  @@unique([workspaceId, key])
  @@index([workspaceId, isActive, position])
}

model AutomationViewColumn {
  id          String               @id @default(uuid())
  workspaceId String
  viewId      String
  key         String
  name        String
  description String?
  color       String
  position    Int                  @default(0)
  isActive    Boolean              @default(true)
  isTerminal  Boolean              @default(false)
  settings    Json?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  workspace   Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  view        AutomationView       @relation(fields: [viewId], references: [id], onDelete: Cascade)
  placements  WorkItemViewPlacement[]

  @@unique([viewId, key])
  @@index([workspaceId, viewId, isActive, position])
}

model WorkItemViewPlacement {
  id          String                @id @default(uuid())
  workspaceId String
  itemId      String
  viewId      String
  columnId    String
  position    Int                   @default(0)
  metadata    Json?
  updatedBy   String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  workspace   Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  item        Item                  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  view        AutomationView        @relation(fields: [viewId], references: [id], onDelete: Cascade)
  column      AutomationViewColumn  @relation(fields: [columnId], references: [id], onDelete: Cascade)
  updater     User?                 @relation("WorkItemViewPlacementUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@unique([itemId, viewId])
  @@index([workspaceId, viewId, columnId, position])
}

model SearchDocument {
  id              String                    @id @default(uuid())
  itemId          String
  workspaceId     String
  boardId         String
  content         String
  embedding       Float[]                  @default([])
  metadata        Json?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  item            Item                      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([workspaceId, boardId])
}

model AIAgent {
  id            String       @id @default(uuid())
  workspaceId   String
  key           String
  name          String
  description   String?
  model         String
  temperature   Float        @default(0.2)
  systemPrompt  String
  config        Json?
  isActive      Boolean      @default(true)
  isDefault     Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  runs          AIAgentRun[]

  @@unique([workspaceId, key])
  @@index([workspaceId, isActive, updatedAt])
}

model AIAgentRun {
  id            String    @id @default(uuid())
  workspaceId   String
  agentId       String
  itemId        String?
  requestedBy   String
  status        String
  input         Json
  output        Json?
  error         String?
  provider      String?
  model         String?
  latencyMs     Int?
  inputTokens   Int?
  outputTokens  Int?
  totalTokens   Int?
  estimatedCostUsd Float?
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  agent         AIAgent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  item          Item?     @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([agentId, createdAt])
  @@index([itemId, createdAt])
}

model DomainOutbox {
  id              String                    @id @default(uuid())
  eventName       String
  aggregateType   String
  aggregateId     String
  payload         Json
  occurredAt      DateTime
  processedAt     DateTime?
  retries         Int                       @default(0)
  nextAttemptAt   DateTime                  @default(now())
  deadLetteredAt  DateTime?
  lastError       String?
  createdAt       DateTime                  @default(now())

  @@index([processedAt, deadLetteredAt, nextAttemptAt])
}

model AuditEvent {
  id              String                    @id @default(uuid())
  eventName       String
  severity        AuditSeverity             @default(INFO)
  actorId         String?
  workspaceId     String?
  metadata        Json?
  happenedAt      DateTime                  @default(now())
}

model TelemetryEvent {
  id          String   @id
  category    String
  eventName   String
  success     Boolean?
  userId      String?
  workspaceId String?
  method      String?
  route       String?
  statusCode  Int?
  durationMs  Int?
  durationNs  BigInt?
  reason      String?
  provider    String?
  ipHash      String?
  country     String?
  city        String?
  userAgent   String?
  browser     String?
  os          String?
  deviceType  String?
  metadata    Json?
  occurredAt  DateTime @default(now())

  @@index([category, eventName, occurredAt])
  @@index([userId, occurredAt])
  @@index([workspaceId, occurredAt])
  @@index([route, occurredAt])
}
