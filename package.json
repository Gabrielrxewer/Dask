{
  "name": "dask-monorepo",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "infra:up": "docker compose -f docker-compose.infra.yml up -d",
    "infra:down": "docker compose -f docker-compose.infra.yml down",
    "infra:logs": "docker compose -f docker-compose.infra.yml logs -f",
    "infra:reset": "docker compose -f docker-compose.infra.yml down -v",
    "dev:app": "npm --prefix dask-app run dev",
    "dev:api": "npm --prefix dask-api run dev",
    "build:app": "npm --prefix dask-app run build",
    "build:api": "npm --prefix dask-api run build",
    "typecheck:app": "npm --prefix dask-app run typecheck",
    "typecheck:api": "npm --prefix dask-api run typecheck",
    "test:app": "npm --prefix dask-app run test",
    "test:api": "npm --prefix dask-api run test",
    "check:app": "npm --prefix dask-app run check",
    "check:api": "npm --prefix dask-api run check",
    "check:all": "npm run check:app && npm run check:api"
  }
}
